{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types", "vitest/globals"],
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "include": ["functions/**/*.ts"]
}
