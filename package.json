{
  "name": "cstd-design",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "test": "node --test scripts/production-smoke.test.mjs && vitest run",
    "test:ui": "vitest --ui",
    "smoke:auth-export": "node scripts/authenticated-export-smoke.mjs",
    "smoke:production": "node scripts/production-smoke.mjs",
    "verify:production-secrets": "node scripts/verify-pages-secrets.mjs",
    "typecheck:functions": "tsc -p tsconfig.functions.json --noEmit",
    "pages:dev": "wrangler pages dev dist",
    "pages:deploy": "wrangler pages deploy dist --project-name=cstd-design --branch=main"
  },
  "dependencies": {
    "lucide-react": "^1.22.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260630.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
